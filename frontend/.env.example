# FinMate API base URL.
# Local backend default: http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080

# true  = run the standalone frontend with built-in mock data.
# false = call the FinMate backend at VITE_API_BASE_URL.
#
# Keep true as the default for local UI work. Set false only when the API,
# database, and synthetic dataset have been restored in gaga-studio/finmate.
VITE_DUMMY_MODE=true
